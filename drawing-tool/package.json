{
  "name": "modern-drawing-tool",
  "private": true,
  "version": "4.1.0",
  "type": "module",
  "description": "2.5K液タブレット特化・ふたば色お絵かきツール",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,css}\""
  },
  "dependencies": {
    "pixi.js": "^8.11.0",
    "file-saver": "^2.0.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "eslint": "^8.55.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "drawing",
    "pixi.js",
    "webgpu",
    "typescript",
    "canvas",
    "digital-art"
  ]
}