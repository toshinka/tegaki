{
  "name": "modern-drawing-tool",
  "version": "3.2.0-phase1",
  "description": "モダンお絵かきツール v3.2: PixiJS統一基盤 + Chrome API活用",
  "type": "module",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite --host",
    "test": "echo 'Phase1: テスト機能はPhase2で実装予定' && exit 0",
    "lint": "echo 'Phase1: リント機能はPhase2で実装予定' && exit 0",
    "validate-phase1": "node scripts/validate-phase1.js"
  },
  "keywords": [
    "drawing",
    "pixi",
    "webgpu",
    "canvas",
    "pixi-unified",
    "chrome-api",
    "digital-art",
    "phase-development"
  ],
  "author": "Modern Drawing Tool Project",
  "license": "MIT",
  "dependencies": {
    "chroma-js": "^3.1.2",
    "lodash-es": "^4.17.21",
    "mitt": "^3.0.1",
    "phosphor-icons": "^1.4.2",
    "pixi.js": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vite": "^5.0.0"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14",
    "Edge >= 90"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/example/modern-drawing-tool"
  },
  "bugs": {
    "url": "https://github.com/example/modern-drawing-tool/issues"
  },
  "homepage": "https://github.com/example/modern-drawing-tool#readme",
  "config": {
    "phase": "1",
    "nextPhase": "2",
    "features": {
      "pixiUnified": true,
      "pixiCoordinateUnifier": true,
      "pixiUnifiedRenderer": true,
      "eventStore": true,
      "basicTools": true,
      "shortcutSystem": true,
      "historySystem": true,
      "phase2Ready": false,
      "phase3Ready": false
    }
  },
  "phase1": {
    "description": "PixiJS統一基盤 + 基本描画機能",
    "completedFeatures": [
      "PixiCoordinateUnifier - PixiJS自然座標系統一",
      "PixiUnifiedRenderer - PixiJS単一エンジン統一",
      "PixiInputController - PixiJS統一入力処理",
      "EventStore - mitt.js統一イベントバス",
      "ShortcutController - キーボードショートカット管理",
      "HistoryController - アンドゥ・リドゥ・状態管理"
    ],
    "fileStructure": {
      "core": [
        "PixiCoordinateUnifier.js",
        "EventStore.js"
      ],
      "renderers": [
        "PixiUnifiedRenderer.js"
      ],
      "controllers": [
        "PixiInputController.js",
        "ShortcutController.js",
        "HistoryController.js"
      ]
    },
    "totalLines": "約2500-3000行",
    "memoryFootprint": "軽量（PixiJS統一基盤のみ）",
    "performance": "60fps保証・PixiJS統一座標最適化"
  },
  "phase2": {
    "description": "Phase2実装予定: ツール・UI・カラー統合",
    "plannedFeatures": [
      "PixiToolProcessor - PixiJS全描画ツール実装",
      "PixiUIController - PixiJS Fresco風UI",
      "ColorProcessor - ふたば色・Chroma.js活用",
      "PixiLayerProcessor - PixiJS非破壊レイヤー管理",
      "CanvasController - PixiJSキャンバス操作制御"
    ],
    "unlockConditions": [
      "Phase1品質検証完了",
      "PixiJS統一システム安定動作確認",
      "PixiJS基本描画機能動作確認"
    ]
  },
  "phase3": {
    "description": "Phase3実装予定: Chrome API活用・高度機能",
    "plannedFeatures": [
      "PixiOffscreenProcessor - Chrome API活用PixiJS並列処理",
      "PixiAnimationController - PixiJS Storyboarder風アニメーション",
      "PixiModernExporter - WebCodecs・PixiJS RenderTexture活用",
      "ProjectStore - PixiJS統合プロジェクト管理"
    ],
    "unlockConditions": [
      "Phase2品質検証完了",
      "PixiJS UIシステム安定動作確認",
      "PixiJS レイヤー管理システム動作確認"
    ]
  },
  "technicalSpecs": {
    "coordinateSystem": {
      "unified": "PixiJS自然座標系",
      "origin": "top-left",
      "yDirection": "down",
      "pixiIntegration": "完全統一",
      "noTransformLayer": "PixiJS標準座標系活用"
    },
    "renderingEngine": {
      "primary": "PixiJS v7.3+ WebGL",
      "fallback": "PixiJS Canvas",
      "coordination": "PixiJS単一エンジン統一制御",
